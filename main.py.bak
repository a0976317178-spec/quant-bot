    emoji = "🟢" if stats["win_rate"] >= 50 else "🔴"
    await update.message.reply_text(
        f"近30天交易績效\n\n"
        f"總交易：{stats['total']} 次\n"
        f"勝率：{emoji} {stats['win_rate']}% ({stats['wins']}勝/{stats['losses']}敗)\n"
